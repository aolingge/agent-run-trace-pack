{
  "name": "agent-run-trace-pack",
  "version": "0.1.0",
  "description": "Pre-release local-first CLI for redacted, reviewable coding-agent trace packs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aolingge/agent-run-trace-pack.git"
  },
  "bugs": {
    "url": "https://github.com/aolingge/agent-run-trace-pack/issues"
  },
  "homepage": "https://aolingge.github.io/agent-run-trace-pack/",
  "bin": {
    "agent-run-trace-pack": "./dist/cli.js",
    "artrace": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "agentRunTracePack": {
    "status": "pre-release",
    "usage": "source-mode until a public npm package exists",
    "node": ">=20",
    "packageContents": [
      "dist",
      "docs",
      "assets",
      "README.md",
      "LICENSE"
    ],
    "manualReleaseOutOfScope": [
      "npm publish",
      "git tag",
      "GitHub release",
      "external posting",
      "credential requirement"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "node scripts/lint.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "smoke": "node dist/cli.js run --out .tmp/smoke -- node -e \"console.log('trace smoke')\" && node scripts/validate-trace.mjs .tmp/smoke",
    "validate:trace": "node scripts/validate-trace.mjs",
    "demo": "node dist/cli.js run --out .tmp/demo -- node -e \"console.log('agent step'); console.error('warning: retry once')\""
  },
  "keywords": [
    "ai-agent",
    "coding-agent",
    "observability",
    "trace",
    "mcp",
    "developer-tools",
    "cli",
    "git",
    "redaction",
    "typescript"
  ],
  "author": "Aolinge",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
