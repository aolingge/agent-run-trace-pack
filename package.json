{
  "name": "agent-run-trace-pack",
  "version": "0.1.1",
  "description": "Local-first CLI for redacted, reviewable coding-agent trace packs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aolingge/agent-run-trace-pack.git"
  },
  "bugs": {
    "url": "https://github.com/aolingge/agent-run-trace-pack/issues"
  },
  "homepage": "https://aolingge.github.io/agent-run-trace-pack/",
  "bin": {
    "agent-run-trace-pack": "dist/cli.js",
    "artrace": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "assets",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "agentRunTracePack": {
    "status": "public-npm-release",
    "usage": "npx agent-run-trace-pack run -- <command>",
    "node": ">=20",
    "packageContents": [
      "dist",
      "docs",
      "assets",
      "README.md",
      "LICENSE"
    ],
    "manualReleaseChecklist": [
      "npm run check",
      "npm run smoke",
      "node scripts/release-dry-run.mjs",
      "npm pack --dry-run --json"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "node scripts/lint.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "smoke": "node dist/cli.js run --out .tmp/smoke -- node -e \"console.log('trace smoke')\" && node scripts/validate-trace.mjs .tmp/smoke",
    "validate:trace": "node scripts/validate-trace.mjs",
    "demo": "node dist/cli.js run --out .tmp/demo -- node -e \"console.log('agent step'); console.error('warning: retry once')\""
  },
  "keywords": [
    "ai-agent",
    "coding-agent",
    "coding-agents",
    "agentic-coding",
    "observability",
    "trace",
    "audit-log",
    "mcp",
    "developer-tools",
    "cli",
    "git",
    "redaction",
    "local-first",
    "typescript"
  ],
  "author": "Aolinge",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
